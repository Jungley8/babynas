# systemd 服务单元（由 install.sh 自动安装到 /etc/systemd/system/）
# 配置在 /opt/babynas/babynas.env，升级时不会被覆盖。
[Unit]
Description=babynas 婴幼儿家庭媒体服务
After=network.target

[Service]
Type=simple
EnvironmentFile=/opt/babynas/babynas.env
# systemd 的 ${VAR} 展开为单个参数，路径含空格也安全
ExecStart=/opt/babynas/babynas -addr ${ADDR} -audio ${AUDIO} -video ${VIDEO} -db ${DB} -pin ${PIN}
WorkingDirectory=/opt/babynas
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
